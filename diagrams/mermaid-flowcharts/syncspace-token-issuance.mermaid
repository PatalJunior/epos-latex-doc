flowchart TB
    client["HTTP client"] -- register --> auth["<b>AuthResource</b><br><i>@Inject UserRepository, TokenService</i>"]
    client -- login --> auth
    auth -- register --> reg{"POST /auth/register<br>username taken?"}
    reg -- yes --> conflict@{ label: "409 Conflict<br><code>'Username exists'</code>" }
    reg -- no --> hash["<b>PasswordUtils</b><br><i>hashPassword()</i>"]
    hash --> insert["UserRepository.insert()"]
    insert --> created["201 Created"]
    auth -- login --> login{"POST /auth/login<br>user found?"}
    login -- no --> unauth@{ label: "401 Unauthorized<br><code>'Invalid password' / 'User not found'</code>" }
    login -- yes --> verify{"<b>PasswordUtils</b><br>verifyPassword()"}
    verify -- mismatch --> unauth
    verify -- match --> token["<b>TokenService</b><br><i>generateToken() · RS256 signed JWT</i><br>sub, upn, groups, exp=1h"]
    token --> ok@{ label: "200 OK<br><code>{ 'token': '...' }</code>" }

    conflict@{ shape: rect}
    unauth@{ shape: rect}
    ok@{ shape: rect}
     client:::stage
     auth:::stage
     reg:::stage
     conflict:::error
     hash:::mapper
     insert:::stage
     created:::outbox
     login:::stage
     verify:::mapper
     unauth:::error
     token:::mapper
     ok:::outbox
    classDef stage fill:#e6f0fa,stroke:#333,stroke-width:2px,color:#000
    classDef error fill:#ffe6e6,stroke:#333,stroke-width:2px,color:#000
    classDef mapper fill:#f4ebf4,stroke:#333,stroke-width:2px,color:#000
    classDef outbox fill:#e6f2e6,stroke:#333,stroke-width:2px,color:#000